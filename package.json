{
  "name": "@heildamm/components",
  "version": "1.0.0",
  "description": "A comprehensive React component library for modern UI design with TypeScript support",
  "author": {
    "name": "glatztp",
    "url": "https://github.com/glatztp"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glatztp/heildamm-components.git"
  },
  "bugs": {
    "url": "https://github.com/glatztp/heildamm-components/issues"
  },
  "homepage": "https://github.com/glatztp/heildamm-components#readme",
  "keywords": [
    "react",
    "components",
    "tailwind",
    "typescript",
    "ui",
    "library",
    "design-system"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:lib": "tsc --declaration --emitDeclarationOnly --outDir dist && tsc --module esnext --target es2020 --outDir dist && tsc --module commonjs --target es2020 --outDir dist",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@vercel/analytics": "^1.4.1",
    "next": "16.1.6",
    "react": "19.2.5",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^10",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^6"
  }
}
